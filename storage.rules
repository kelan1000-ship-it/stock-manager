rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Product Images: All staff can view, only admins can upload/delete
    match /products/{productId}/{imageId=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Branch Communications: Authenticated users can read/write
    match /branch_communications/{branchId}/{imageId=**} {
      allow read, write: if isAuthenticated();
    }

    // Task Manager: Authenticated users can read/write
    match /task_manager/{taskId}/{imageId=**} {
      allow read, write: if isAuthenticated();
    }

    // Planogram: Authenticated users can read/write
    match /planogram/{planogramId}/{imageId=**} {
      allow read, write: if isAuthenticated();
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
