rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isAuth() && getUserData().role == 'admin'; }

    // User profiles
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
      allow update: if isAuth() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']);
    }

    // Branch products — any authenticated user can read/write any branch
    match /branches/{branchId}/products/{docId} {
      allow read, write: if isAuth();
    }

    // All shared data (messages, transfers, requests, orders, etc.)
    // The {path=**} wildcard matches any depth of subcollections
    match /shared/{document=**} {
      allow read, write: if isAuth();
    }

    // Planograms
    match /planograms/{docId} {
      allow read, write: if isAuth();
    }

    // Floor Plans
    match /floorPlans/{docId} {
      allow read, write: if isAuth();
    }
  }
}
