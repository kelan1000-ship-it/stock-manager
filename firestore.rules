rules_version = '2';
// Force redeploy v2
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    
    function isAdmin() {
      return isAuth() && exists(userDoc()) && get(userDoc()).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow write: if isAdmin();
      allow update: if isAuth() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin']);
    }

    // Branch products — any authenticated user can read/write any branch
    match /branches/{branchId}/products/{docId} {
      allow read, write: if isAuth();
    }

    // Branch-specific data (Requests, Planograms, Floor Plans)
    match /branches/{branchId}/requests/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/planograms/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/floorPlans/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/eposTransactions/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/eposQuickButtons/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/eposZReads/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/staffMembers/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/staffShifts/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/staffHolidays/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/shiftPresets/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/config/{docId} {
      allow read, write: if isAuth();
    }

    match /branches/{branchId}/dayOverrides/{docId} {
      allow read, write: if isAuth();
    }

    // All shared data (messages, transfers, orders, etc.)
    match /shared/{document=**} {
      allow read, write: if isAuth();
    }
  }
}
